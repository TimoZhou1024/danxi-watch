DANXI_BASE_URLS=https://forum.fduhole.com/api,https://api.fduhole.com
DANXI_ALLOWED_READ_HOSTS=forum.fduhole.com,api.fduhole.com
DANXI_ALLOWED_POST_HOSTS=forum.fduhole.com,api.fduhole.com
# Optional: leave blank to auto-fetch via WebVPN credentials when possible.
DANXI_API_TOKEN=
## WebVPN fallback
DANXI_WEBVPN_MODE=auto
DANXI_WEBVPN_USERNAME=
DANXI_WEBVPN_PASSWORD=
DANXI_WEBVPN_SAVE_CREDENTIALS=true
DANXI_ARCHIVE_OUTPUTS=true
DANXI_ARCHIVE_DIR=outputs/history
DANXI_FLOOR_ENRICH_SIZE=40
DANXI_FLOOR_ENRICH_WORKERS=6
DANXI_FLOOR_ENRICH_TIMEOUT=8
DANXI_FLOOR_CACHE_FILE=outputs/floors_cache.json
DANXI_WATCH_RULES=rules/watch_rules.json
DANXI_OUTPUT_DETECTIONS=outputs/detections.json
DANXI_OUTPUT_DETECTIONS_MARKDOWN=outputs/detections.md
DANXI_MAX_DETECTIONS_PER_RULE=20
DANXI_ARCHIVE_DB=data/danxi.sqlite
DANXI_IMAGE_ROOT=data/images
DANXI_ARCHIVE_HOURS=24
DANXI_ARCHIVE_INTERVAL_MINUTES=10
DANXI_LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
DANXI_POST_ENDPOINT=
DANXI_POST_TOKEN=
DANXI_POST_AT=
